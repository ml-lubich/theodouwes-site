{
  "name": "theodouwes-site",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test": "bun test ./src --coverage",
    "test:unit": "bun test ./src/lib --coverage",
    "test:integration": "bun test ./src/__tests__/integration --coverage",
    "test:coverage": "bun test ./src --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:all": "bun test ./src --coverage && playwright test"
  },
  "dependencies": {
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.1",
    "geist": "^1.7.2",
    "next": "^15.3.4",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "three": "^0.185.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.53.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^22.15.32",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@types/three": "^0.185.1",
    "eslint": "^9.29.0",
    "eslint-config-next": "^15.3.4",
    "happy-dom": "^20.10.6",
    "sharp": "^0.35.3",
    "typescript": "^5.8.3"
  }
